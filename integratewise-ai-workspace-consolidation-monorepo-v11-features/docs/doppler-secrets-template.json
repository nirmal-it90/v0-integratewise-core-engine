{
  "$schema": "https://docs.doppler.com/docs/secrets-schema",
  "description": "IntegrateWise Doppler Secrets Template",
  "version": "1.0.0",
  "secrets": {
    "authentication": {
      "NEXTAUTH_URL": {
        "description": "Canonical URL for NextAuth callbacks",
        "type": "string",
        "required": true,
        "examples": {
          "dev": "http://localhost:3000",
          "stg": "https://preview.integratewise.co",
          "prd": "https://app.integratewise.co"
        }
      },
      "NEXTAUTH_SECRET": {
        "description": "Secret for JWT signing and encryption (generate with: openssl rand -base64 32)",
        "type": "string",
        "required": true,
        "sensitive": true,
        "rotation_cadence": "90d"
      },
      "GOOGLE_CLIENT_ID": {
        "description": "Google OAuth client ID from Google Cloud Console",
        "type": "string",
        "required": true
      },
      "GOOGLE_CLIENT_SECRET": {
        "description": "Google OAuth client secret",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "CLERK_SECRET_KEY": {
        "description": "Clerk authentication secret key",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "CLERK_PUBLISHABLE_KEY": {
        "description": "Clerk publishable key (safe for client-side)",
        "type": "string",
        "required": true,
        "sensitive": false
      }
    },
    "database": {
      "DATABASE_URL": {
        "description": "Neon Postgres pooled connection string (for Prisma queries)",
        "type": "string",
        "required": true,
        "sensitive": true,
        "format": "postgresql://{user}:{password}@{host}/{database}?sslmode=require&pgbouncer=true"
      },
      "DATABASE_URL_UNPOOLED": {
        "description": "Neon Postgres direct connection (for migrations)",
        "type": "string",
        "required": true,
        "sensitive": true,
        "format": "postgresql://{user}:{password}@{host}/{database}?sslmode=require"
      }
    },
    "ai": {
      "XAI_API_KEY": {
        "description": "xAI (Grok) API key",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "ANTHROPIC_API_KEY": {
        "description": "Anthropic Claude API key",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "OPENAI_API_KEY": {
        "description": "OpenAI API key",
        "type": "string",
        "required": true,
        "sensitive": true
      }
    },
    "payments": {
      "STRIPE_SECRET_KEY": {
        "description": "Stripe API secret key",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "STRIPE_WEBHOOK_SECRET": {
        "description": "Stripe webhook signing secret (whsec_...)",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "STRIPE_PUBLISHABLE_KEY": {
        "description": "Stripe publishable key (safe for client-side)",
        "type": "string",
        "required": false,
        "sensitive": false
      }
    },
    "infrastructure": {
      "CLOUDFLARE_API_TOKEN": {
        "description": "Cloudflare API token with Workers/Pages permissions",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "CLOUDFLARE_ACCOUNT_ID": {
        "description": "Cloudflare account ID",
        "type": "string",
        "required": true,
        "sensitive": false
      },
      "VERCEL_TOKEN": {
        "description": "Vercel deployment token",
        "type": "string",
        "required": true,
        "sensitive": true
      },
      "VERCEL_ORG_ID": {
        "description": "Vercel organization/team ID",
        "type": "string",
        "required": false,
        "sensitive": false
      },
      "VERCEL_PROJECT_ID": {
        "description": "Vercel project ID for hub-frontend-app",
        "type": "string",
        "required": false,
        "sensitive": false
      }
    },
    "integrations": {
      "HUBSPOT_CLIENT_ID": {
        "description": "HubSpot OAuth client ID",
        "type": "string",
        "required": false
      },
      "HUBSPOT_CLIENT_SECRET": {
        "description": "HubSpot OAuth client secret",
        "type": "string",
        "required": false,
        "sensitive": true
      },
      "HUBSPOT_WEBHOOK_SECRET": {
        "description": "HubSpot webhook signing secret",
        "type": "string",
        "required": false,
        "sensitive": true
      }
    },
    "observability": {
      "SENTRY_DSN": {
        "description": "Sentry error tracking DSN",
        "type": "string",
        "required": false
      },
      "SENTRY_AUTH_TOKEN": {
        "description": "Sentry auth token for source maps",
        "type": "string",
        "required": false,
        "sensitive": true
      }
    }
  }
}
