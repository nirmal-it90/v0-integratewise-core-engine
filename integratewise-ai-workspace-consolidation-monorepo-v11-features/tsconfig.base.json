{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@integratewise/ui": ["packages/ui/src/index.ts"],
      "@integratewise/ui/*": ["packages/ui/src/*"],
      "@integratewise/config": ["packages/config/src/index.ts"],
      "@integratewise/config/*": ["packages/config/src/*"],
      "@integratewise/lib": ["packages/lib/src/index.ts"],
      "@integratewise/lib/*": ["packages/lib/src/*"],
      "@integratewise/types": ["packages/types/src/index.ts"],
      "@integratewise/types/*": ["packages/types/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build"]
}
