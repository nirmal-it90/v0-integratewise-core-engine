  "implementation_phases": [
    {
      "phase": 1,
      "name": "SPINE Schema",
      "weeks": "Week 1",
      "layers": ["NORMALIZE"],
      "deliverables": [
        "Run all SPINE SQL migrations",
        "Create spine/types.ts",
        "Create spine/queries.ts",
        "Create spine/mutations.ts",
        "Create SPINE API endpoints"
      ]
    },
    {
      "phase": 2,
      "name": "Stage 2 Loader",
      "weeks": "Weeks 2-3",
      "layers": ["LOAD"],
      "deliverables": [
        "Complete file parsers",
        "Implement entity extraction",
        "Create upload API",
        "Build processing UI"
      ]
    },
    {
      "phase": 3,
      "name": "Memory Layer",
      "weeks": "Weeks 4-5",
      "layers": ["THINK"],
      "deliverables": [
        "Run memory SQL migration",
        "Implement 3-tier memory",
        "Create embedding service",
        "Build context builder"
      ]
    },
    {
      "phase": 4,
      "name": "OAuth Connectors",
      "weeks": "Weeks 6-7",
      "layers": ["CONNECTORS"],
      "deliverables": [
        "Run integrations SQL migration",
        "Implement OAuth registry",
        "Create HubSpot/Google/Slack providers",
        "Build sync engine"
      ]
    },
    {
      "phase": 5,
      "name": "n8n Workflows",
      "weeks": "Weeks 8-9",
      "layers": ["NORMALIZE"],
      "deliverables": [
        "Create 17 normalizer workflows",
        "Create 8 orchestrator workflows",
        "Deploy to n8n instance"
      ]
    },
    {
      "phase": 6,
      "name": "Brain Agent",
      "weeks": "Weeks 10-11",
      "layers": ["ACT"],
      "deliverables": [
        "Run brain agent SQL migrations",
        "Implement pattern analyzer",
        "Create suggestion generator",
        "Build action executor"
      ]
    },
    {
      "phase": 7,
      "name": "Domain Views",
      "weeks": "Weeks 12-15",
      "layers": ["ALL"],
      "deliverables": [
        "Merge 16 views from integrate-wise-2",
        "Implement CS-First views",
        "Create 13 practitioner domain views"
      ]
    },
    {
      "phase": 8,
      "name": "Cycle Engine",
      "weeks": "Week 16",
      "layers": ["REPEAT", "GOVERN"],
      "deliverables": [
        "Run cycle/audit SQL migrations",
        "Implement cycle executor",
        "Create report generator",
        "Deploy cron jobs"
      ]
    }
  ]
