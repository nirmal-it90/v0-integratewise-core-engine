{
  "name": "integratewise-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "IntegrateWise Monorepo - Business OS, Customer Success, Core Engine",
  "keywords": [
    "integratewise",
    "monorepo",
    "automation",
    "customer-success"
  ],
  "license": "MIT",
  "author": "IntegrateWise",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:engine": "turbo build --filter=@integratewise/core-engine",
    "build:hub": "turbo build --filter=@integratewise/hub",
    "build:os": "turbo build --filter=@integratewise/os",
    "clean": "turbo clean && rm -rf node_modules",
    "dev": "turbo dev",
    "dev:engine": "turbo dev --filter=@integratewise/core-engine",
    "dev:hub": "turbo dev --filter=@integratewise/hub",
    "dev:os": "turbo dev --filter=@integratewise/os",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "prepare": "node -e \"if(!process.env.VERCEL)require('child_process').execSync('lefthook install',{stdio:'inherit'})\"",
    "test": "turbo test",
    "test:unit": "turbo test --filter='./apps/*' --filter='./packages/*'",
    "test:integration": "turbo test:integration",
    "typecheck": "turbo typecheck",
    "preflight": "pnpm install --frozen-lockfile && pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "latest",
    "@hookform/resolvers": "3.10.0",
    "@integratewise/lib": "workspace:*",
    "@integratewise/types": "workspace:*",
    "@integratewise/ui": "workspace:*",
    "@microsoft/api-extractor": "latest",
    "@neondatabase/serverless": "1.0.0",
    "@next/eslint-plugin-next": "16.0.10",
    "@notionhq/client": "2.2.15",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.90.1",
    "@swc/core": "latest",
    "@swc/helpers": "latest",
    "@tailwindcss/postcss": "4.1.9",
    "@vercel/analytics": "1.3.1",
    "@vercel/speed-insights": "1.3.1",
    "ai": "5.0.115",
    "autoprefixer": "10.4.20",
    "class-variance-authority": "0.7.1",
    "cloudinary": "2.0.0",
    "clsx": "2.1.1",
    "cmdk": "1.0.4",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.5.1",
    "eslint-plugin-react": "7.37.5",
    "express": "5.2.1",
    "framer-motion": "12.23.26",
    "globals": "17.0.0",
    "hono": "4.6.0",
    "input-otp": "1.4.1",
    "lucide-react": "0.454.0",
    "next": "16.0.10",
    "next-cloudinary": "6.6.2",
    "next-themes": "0.4.6",
    "react": "19.2.0",
    "react-day-picker": "9.8.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.60.0",
    "react-resizable-panels": "2.1.7",
    "recharts": "2.15.4",
    "sonner": "1.7.4",
    "stripe": "14.0.0",
    "swr": "2.3.8",
    "tailwind-merge": "3.3.1",
    "tailwindcss-animate": "1.0.7",
    "tw-animate-css": "1.2.8",
    "tsup": "8.5.1",
    "typescript-eslint": "8.52.0",
    "uuid": "13.0.0",
    "vaul": "1.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.17.0",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.0.13",
    "postcss": "8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.9",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=10.0.0"
  }
}
